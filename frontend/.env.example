# Sentry (frontend): if set, errors and performance traces are sent to Sentry
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Optional: for Sentry source maps upload during build (then sourcemaps are not disabled)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=...
# SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1  # to silence the global-error warning in build

# API and site URL (if needed)
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
