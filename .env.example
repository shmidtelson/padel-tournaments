# Copy to .env and adjust. Used by backend and docker-compose context.

# Database (async for FastAPI). With docker compose, Postgres listens on host port 5433.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/padel_tournaments

# For Procrastinate worker (sync URL); with docker compose use host port 5433.
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5433/padel_tournaments

# JWT (production: min 32 chars; app refuses to start with default if DEBUG=false)
SECRET_KEY=change-me-in-production-use-env

# Production: set to your frontend origin(s), comma-separated (e.g. https://app.example.com)
CORS_ORIGINS=

# Production: allowed base URL for Stripe checkout success_url/cancel_url (e.g. https://app.example.com)
ALLOWED_FRONTEND_BASE_URL=

# Stripe (for org subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# Private API docs: if set, /docs and /openapi.json require ?docs_key=... or header X-Docs-Key
DOCS_SECRET_KEY=

# Sentry (backend): if set, errors and traces are sent to Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
